{
  "name": "lightbox3",
  "version": "1.0.0",
  "description": "Modern image lightbox with physics-based touch interactions",
  "author": "Lokesh Dhakar",
  "license": "MIT",
  "keywords": [
    "lightbox",
    "image",
    "gallery",
    "zoom",
    "modal",
    "viewer",
    "responsive",
    "touch",
    "pinch-to-zoom",
    "swipe"
  ],
  "type": "module",
  "main": "dist/lightbox3.umd.js",
  "module": "dist/lightbox3.esm.js",
  "types": "dist/index.d.ts",
  "style": "dist/lightbox3.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lightbox3.esm.js",
      "require": "./dist/lightbox3.umd.js"
    },
    "./style.css": "./dist/lightbox3.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/lightbox3.css"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,css}'",
    "build:site": "bash scripts/build-site.sh",
    "deploy": "bash scripts/deploy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lokesh/lightbox3.git"
  },
  "bugs": {
    "url": "https://github.com/lokesh/lightbox3/issues"
  },
  "homepage": "https://github.com/lokesh/lightbox3#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "rollup": "^4.30.0",
    "rollup-plugin-postcss": "^4.0.2",
    "serve": "^14.2.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
